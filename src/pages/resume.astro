---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Role {
  company: string;
  title: string;
  location?: string;
  start: string;
  end: string;
  bullets: string[];
}

const roles: Role[] = [
  {
    company: "Overhaul",
    title: "Software Development Engineer III",
    location: "Ann Arbor, MI",
    start: "Aug 2025",
    end: "Present",
    bullets: [
      "Driving monolith-to-microservices migration, new developer tooling, and organizational shifts across the engineering org through the post-acquisition transition.",
      "Stepping into broader platform leadership and stewardship — architectural decisions, cross-team integration, and long-term system health across services.",
      "Going deep on AI engineering — agentic coding, context engineering, and the harness design that separates a chatbot from a working system.",
    ],
  },
  {
    company: "FreightVerify (acquired by Overhaul, Aug 2025)",
    title: "Software Engineer → Senior Software Engineer",
    location: "Ann Arbor, MI",
    start: "Apr 2019",
    end: "Aug 2025",
    bullets: [
      "Joined as an intern in April 2019 fresh from Ferris State; promoted through Software Engineer (Sep 2019) to Senior Software Engineer (Aug 2022).",
      "Led PartView, FreightVerify's aftermarket-parts visibility product — tracking tens of millions of parts every month with 95% ETA accuracy across a platform that handles 100M+ shipments for six of the world's largest automotive manufacturers.",
      "Major contributor to flagship VinView — a real-time VIN tracker used daily by 70K monthly super users (parts managers, sales admins, and dealer ops) at GM, Ford, Honda, and Hyundai; recently earned a world-class NPS of 83.",
      "Cloud-native systems on AWS — Kubernetes, Lambda, SQS/SNS — with observability via Datadog and Rollbar; chain-of-custody and audit pathways across the platform.",
    ],
  },
  {
    company: "Sleeping Bear Gallery",
    title: "Web Developer (Freelance)",
    location: "Up North, MI",
    start: "May 2017",
    end: "Aug 2018",
    bullets: [
      "Built and maintained a WordPress site for a Northern Michigan art gallery during college — design, theme customization, content management.",
    ],
  },
];

const skills = {
  Languages: ["Python", "Java", "TypeScript", "JavaScript", "SQL"],
  "Cloud & Infra": [
    "AWS (Lambda, S3, SQS/SNS, CloudFront, Route 53)",
    "Kubernetes",
    "Docker",
    "Kafka",
    "Terraform",
    "Serverless Framework",
  ],
  "Backend & Data": [
    "Microservices architecture",
    "REST APIs",
    "FastAPI",
    "Spring Boot",
    "Real-time eventing",
    "Postgres",
    "OpenSearch",
    "Schema design & migrations",
  ],
  "Security & Operations": [
    "RBAC / capability systems",
    "Audit logging",
    "Secrets management",
    "Datadog / Rollbar / observability",
    "On-call",
  ],
  Frontend: ["React", "React Native", "Astro", "Tailwind CSS", "Vite"],
  "AI / Agents": [
    "Agentic engineering",
    "Context engineering",
    "Harness design",
    "Anthropic Claude API",
    "OpenAI API",
    "MCP (Model Context Protocol)",
    "RAG / vector retrieval",
    "Multi-agent orchestration",
  ],
};

const projects = [
  {
    name: "Obscura",
    href: "https://github.com/ElliottBregni/obscura",
    blurb:
      "A personal AI agent runtime built as a sandbox for harness engineering, agentic coding, and security-first design. Capability-gated tool access, RBAC, and per-call audit logging. Multi-backend across Claude, OpenAI, and local LLMs with CLI and an MCP server that extends Claude Code with custom workflows.",
  },
];
---

<BaseLayout
  title="Résumé · Elliott Bregni"
  description="Résumé of Elliott Bregni — Software Development Engineer III at Overhaul, based in Ann Arbor, MI."
  ogTitle="Elliott Bregni — Résumé"
  ogDescription="Senior software engineer · Ann Arbor, MI · 10+ years building software, 7+ scaling supply-chain visibility from FreightVerify through the Overhaul acquisition."
  ogUrl="https://elliott.bregni.com/resume/"
>
  <!-- Sticky toolbar — hidden on print -->
  <div
    class="resume-toolbar fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-zinc-950/85 border-b border-zinc-900"
  >
    <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
      <a
        href="/"
        class="font-mono text-sm text-zinc-400 hover:text-white transition-colors"
      >
        ← elliott.bregni.com
      </a>
      <a
        href="/elliott-bregni-resume.pdf"
        download="Elliott-Bregni-Resume.pdf"
        class="px-4 py-2 bg-white text-black text-sm font-semibold rounded-md hover:bg-zinc-100 transition-colors flex items-center gap-2"
      >
        <span>Download PDF</span>
        <span class="text-xs">↓</span>
      </a>
    </div>
  </div>

  <main class="resume max-w-3xl mx-auto px-6 pt-28 pb-20">
    <!-- Header -->
    <header class="mb-10">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-2 leading-[1.05]">
        Elliott Bregni
      </h1>
      <p class="text-zinc-400 text-lg mb-4">
        Software Development Engineer III @ Overhaul
      </p>
      <div
        class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-zinc-400 font-mono"
      >
        <span>Ann Arbor, MI</span>
        <a
          href="mailto:elliott.bregni@gmail.com"
          class="text-indigo-400 hover:text-indigo-300"
          >elliott.bregni@gmail.com</a
        >
        <a
          href="https://github.com/ElliottBregni"
          class="text-indigo-400 hover:text-indigo-300"
          target="_blank"
          rel="noopener">github.com/ElliottBregni</a
        >
        <a
          href="https://www.linkedin.com/in/elliott-bregni-07a562a7"
          class="text-indigo-400 hover:text-indigo-300"
          target="_blank"
          rel="noopener">linkedin.com/in/elliott-bregni</a
        >
      </div>
    </header>

    <!-- Summary -->
    <section class="mb-10">
      <h2 class="resume-h2">Summary</h2>
      <p class="text-zinc-300 leading-relaxed">
        Senior software engineer with <span class="text-white">10+ years building
        software</span> and <span class="text-white">7+ scaling enterprise
        supply-chain visibility</span> from FreightVerify through the Overhaul
        acquisition. Now expanding into broader platform leadership and
        stewardship while going deep on modern AI engineering.
      </p>
    </section>

    <!-- Experience -->
    <section class="mb-10">
      <h2 class="resume-h2">Experience</h2>
      <div class="space-y-7">
        {
          roles.map((r) => (
            <article>
              <div class="flex items-baseline justify-between gap-4 flex-wrap mb-1">
                <h3 class="text-lg font-semibold text-white">{r.company}</h3>
                <span class="font-mono text-xs text-zinc-500 shrink-0">
                  {r.start} — {r.end}
                </span>
              </div>
              <div class="flex items-baseline justify-between gap-4 flex-wrap mb-2">
                <p class="text-zinc-300 text-sm italic">{r.title}</p>
                {r.location && (
                  <span class="font-mono text-xs text-zinc-500">{r.location}</span>
                )}
              </div>
              <ul class="space-y-1.5 text-zinc-400 text-sm leading-relaxed">
                {r.bullets.map((b) => (
                  <li class="flex gap-3">
                    <span class="text-indigo-400 mt-0.5 shrink-0">→</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Personal projects -->
    <section class="mb-10">
      <h2 class="resume-h2">Personal Project</h2>
      <div class="space-y-4">
        {
          projects.map((p) => (
            <article>
              <div class="flex items-baseline gap-3 flex-wrap mb-1">
                <h3 class="text-lg font-semibold text-white">{p.name}</h3>
                <a
                  href={p.href}
                  target="_blank"
                  rel="noopener"
                  class="font-mono text-xs text-indigo-400 hover:text-indigo-300"
                >
                  {p.href.replace("https://", "")}
                </a>
              </div>
              <p class="text-zinc-400 text-sm leading-relaxed">{p.blurb}</p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Skills -->
    <section class="mb-10">
      <h2 class="resume-h2">Skills</h2>
      <dl class="space-y-2 text-sm">
        {
          Object.entries(skills).map(([category, items]) => (
            <div class="grid grid-cols-[140px_1fr] gap-4 items-baseline">
              <dt class="font-mono text-xs uppercase tracking-wider text-zinc-500">
                {category}
              </dt>
              <dd class="text-zinc-300">{items.join(" · ")}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- Education -->
    <section class="mb-10">
      <h2 class="resume-h2">Education</h2>
      <article>
        <div class="flex items-baseline justify-between gap-4 flex-wrap mb-1">
          <h3 class="text-lg font-semibold text-white">Ferris State University</h3>
          <span class="font-mono text-xs text-zinc-500">2014 — 2019</span>
        </div>
        <p class="text-zinc-300 text-sm">
          B.S. Computer &amp; Information Systems Security / Information Assurance
        </p>
      </article>
    </section>

  </main>

</BaseLayout>

<style is:global>
  .resume {
    font-feature-settings: "ss01", "cv11";
  }
  .resume-h2 {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #a78bfa;
    margin-bottom: 0.85rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #27272a;
  }

  /* Print: clean white, hide chrome, tight single-page layout */
  @media print {
    /* Margin 0 on @page suppresses the browser-injected URL/title/date headers
       in most browsers; we move the page margin into .resume padding instead. */
    @page {
      size: letter;
      margin: 0;
    }
    html,
    body {
      background: #fff !important;
      color: #111 !important;
      font-size: 10pt;
      line-height: 1.35;
      margin: 0 !important;
    }
    .resume-toolbar {
      display: none !important;
    }
    .resume {
      max-width: none !important;
      padding: 0.4in !important;
      margin: 0 !important;
    }

    /* Header */
    .resume header {
      margin-bottom: 0.7rem !important;
    }
    .resume header h1 {
      font-size: 1.55rem !important;
      line-height: 1.05 !important;
      margin-bottom: 0.1rem !important;
    }
    .resume header > p {
      font-size: 0.92rem !important;
      margin-bottom: 0.35rem !important;
    }

    /* Sections */
    .resume section {
      margin-bottom: 0.7rem !important;
    }
    .resume-h2 {
      color: #6d28d9 !important;
      border-color: #ddd !important;
      margin-bottom: 0.4rem !important;
      padding-bottom: 0.2rem !important;
      font-size: 0.62rem !important;
    }

    /* Experience spacing */
    .resume .space-y-7 > * + *,
    .resume .space-y-4 > * + * {
      margin-top: 0.55rem !important;
    }
    .resume article h3 {
      font-size: 0.98rem !important;
      line-height: 1.2 !important;
    }
    .resume article p,
    .resume article dd {
      font-size: 0.85rem !important;
      line-height: 1.35 !important;
    }
    .resume article > div {
      margin-bottom: 0.15rem !important;
    }

    /* Bullets — tighter */
    .resume article ul {
      margin-top: 0.25rem !important;
    }
    .resume article ul.space-y-1\.5 > * + * {
      margin-top: 0.18rem !important;
    }
    .resume article li {
      font-size: 0.85rem !important;
      line-height: 1.35 !important;
    }
    .resume article li span:first-child {
      margin-right: 0.1rem !important;
    }

    /* Skills dl */
    .resume dl > div {
      font-size: 0.85rem !important;
      line-height: 1.3 !important;
      gap: 0.5rem !important;
    }
    .resume dl > div + div {
      margin-top: 0.25rem !important;
    }
    .resume dt {
      font-size: 0.62rem !important;
    }

    /* Footer */
    .resume footer {
      border-color: #ddd !important;
      margin-top: 0.7rem !important;
      padding-top: 0.35rem !important;
      font-size: 0.65rem !important;
    }

    /* Color overrides for print legibility */
    .resume h1,
    .resume h3,
    .resume strong,
    .resume .text-white {
      color: #000 !important;
    }
    .resume p,
    .resume li,
    .resume dd,
    .resume span {
      color: #222 !important;
    }
    .resume .text-zinc-500,
    .resume .text-zinc-400,
    .resume .text-zinc-600 {
      color: #555 !important;
    }
    .resume a,
    .resume .text-indigo-400 {
      color: #6d28d9 !important;
      text-decoration: none !important;
    }
    .resume article em,
    .resume article .italic {
      color: #444 !important;
    }

    /* Page-break hygiene */
    .resume article {
      page-break-inside: avoid;
    }
    .resume section {
      page-break-inside: avoid;
    }
    .resume header {
      page-break-after: avoid;
    }
    .resume-h2 {
      page-break-after: avoid;
    }
  }
</style>
