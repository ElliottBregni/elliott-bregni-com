---
// Projects grid. Add new entries by extending the projects array below.

interface Project {
  name: string;
  status: string;
  statusColor: "emerald" | "amber" | "indigo";
  description: string;
  tags: string[];
  href: string;
  terminal: { type: "cmd" | "out" | "ok" | "warn"; text: string }[];
}

const projects: Project[] = [
  {
    name: "Obscura",
    status: "BETA",
    statusColor: "emerald",
    description:
      "Production-grade AI agent runtime — security-first by design. Capability-gated tool access, RBAC, per-call audit logging, and pluggable secrets management. CLI, REST API, Web UI, and MCP server. Supports Claude, OpenAI, GitHub Copilot, and local LLMs with 100+ tools, vector memory, and 49 plugin integrations.",
    tags: ["Python", "FastAPI", "MCP", "Qdrant", "RBAC", "Audit log"],
    href: "https://github.com/ElliottBregni/obscura",
    terminal: [
      { type: "cmd", text: "$ obscura run --backend claude --audit on" },
      { type: "ok", text: "✓ session started · 49 plugins · rbac: enforced · v2026.3" },
      { type: "out", text: "  capabilities: 5/24 granted · audit: deep.jsonl · secrets: vault" },
    ],
  },
];

const statusClasses: Record<Project["statusColor"], string> = {
  emerald: "bg-emerald-500/10 border-emerald-500/20 text-emerald-400",
  amber: "bg-amber-500/10 border-amber-500/20 text-amber-400",
  indigo: "bg-indigo-500/10 border-indigo-500/20 text-indigo-400",
};
---

<section id="projects" class="border-t border-zinc-900">
  <div class="max-w-6xl mx-auto px-6 py-28">
    <div class="section-label reveal">/ PROJECTS</div>
    <div class="grid gap-4">
      {
        projects.map((p, i) => (
          <div class={`card-border-wrap reveal reveal-d${Math.min(i + 2, 5)}`}>
            <div class="card-inner tilt-card p-8" data-href={p.href}>
              <div class="flex items-start justify-between gap-6">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-3">
                    <h3 class="text-2xl font-semibold">{p.name}</h3>
                    <span
                      class={`font-mono text-xs px-2 py-0.5 border rounded-md ${statusClasses[p.statusColor]}`}
                    >
                      {p.status}
                    </span>
                  </div>
                  <p class="text-zinc-400 mb-4 max-w-3xl leading-relaxed">{p.description}</p>
                  <div class="flex flex-wrap gap-2 mb-4">
                    {p.tags.map((t) => (
                      <span class="font-mono text-xs px-2 py-1 bg-zinc-900 border border-zinc-800 rounded text-zinc-400">
                        {t}
                      </span>
                    ))}
                  </div>
                  <div class="terminal">
                    {p.terminal.map((line) => (
                      <div>
                        <span class={`t-${line.type}`}>{line.text}</span>
                      </div>
                    ))}
                    <div>
                      <span class="t-cmd">❯</span> <span class="t-cursor">▋</span>
                    </div>
                  </div>
                </div>
                <a
                  href={p.href}
                  target="_blank"
                  rel="noopener"
                  class="text-zinc-600 hover:text-indigo-400 transition-colors text-2xl mt-1 shrink-0"
                >
                  ↗
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
