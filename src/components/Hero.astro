---
// Hero (currently hidden).
---

<section
  id="hero"
  class="relative flex items-center grid-bg overflow-hidden border-t border-zinc-900"
  hidden
>
  <div class="hero-glow"></div>
  <div class="hero-fade"></div>
  <div class="relative max-w-6xl mx-auto px-6 pt-32 pb-32 w-full">
    <p class="text-lg md:text-xl text-zinc-400 max-w-xl mb-4 leading-relaxed">
      Agents, runtimes, and developer tools.
    </p>
    <p class="font-mono text-sm text-zinc-600 mb-10 min-h-[1.5rem]">
      <span id="typewriter"></span>
    </p>
    <div class="flex flex-wrap gap-3">
      <a
        href="#projects"
        class="px-5 py-3 bg-white text-black text-sm font-semibold rounded-lg hover:bg-zinc-100 transition-colors"
        >See the work →</a
      >
      <a
        href="/login"
        class="px-5 py-3 border border-zinc-800 text-zinc-100 text-sm font-medium rounded-lg hover:bg-zinc-900 hover:border-indigo-400/40 transition-all"
        >Sign in</a
      >
    </div>
  </div>
</section>
