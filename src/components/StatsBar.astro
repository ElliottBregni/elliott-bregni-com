---
// Stats bar (currently hidden).
---

<div class="stats-bar bg-zinc-950/90 backdrop-blur-sm" hidden>
  <div class="max-w-6xl mx-auto px-6 py-5 flex flex-wrap items-center">
    <div
      class="flex-1 min-w-[120px] flex flex-col items-center border-r border-zinc-800 px-4 first:pl-0"
    >
      <span class="font-mono text-2xl font-bold text-white">49</span>
      <span class="font-mono text-xs text-zinc-500 mt-0.5">PLUGINS</span>
    </div>
    <div
      class="flex-1 min-w-[120px] flex flex-col items-center border-r border-zinc-800 px-4"
    >
      <span class="font-mono text-2xl font-bold text-white">100+</span>
      <span class="font-mono text-xs text-zinc-500 mt-0.5">TOOLS</span>
    </div>
    <div
      class="flex-1 min-w-[120px] flex flex-col items-center border-r border-zinc-800 px-4"
    >
      <span class="font-mono text-2xl font-bold text-white">6</span>
      <span class="font-mono text-xs text-zinc-500 mt-0.5">INTEGRATIONS</span>
    </div>
    <div
      class="flex-1 min-w-[120px] flex flex-col items-center border-r border-zinc-800 px-4"
    >
      <span class="font-mono text-2xl font-bold text-white">v2026</span>
      <span class="font-mono text-xs text-zinc-500 mt-0.5">CURRENT</span>
    </div>
    <div class="hidden lg:flex flex-1 min-w-[180px] flex-col items-end px-4">
      <span class="font-mono text-xs text-emerald-400 flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse inline-block"
        ></span>ALL SYSTEMS OPERATIONAL
      </span>
    </div>
  </div>
</div>
