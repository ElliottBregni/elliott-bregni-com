---
// Modernized AI LLC — the IP holding container.
---

<section id="AI" class="border-t border-zinc-900">
  <div class="max-w-6xl mx-auto px-6 py-28">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="md:col-span-2 reveal reveal-d2">
        <h2
          class="text-3xl md:text-5xl font-bold tracking-tight shimmer-text-rev mb-6 leading-[1.05]"
        >
          Modernized AI LLC
        </h2>
        <div class="text-lg text-zinc-300 leading-relaxed space-y-5">
          <p>
            An intellectual-property holding company. It owns the trademarks, codebases,
            and creative work behind the projects shipped on this site.
          </p>
          <p>
            It isn't an agency, a consultancy, or a product company. It's a quiet legal
            container — the place where the work lives so it can be licensed, partnered
            on, or spun out without friction.
          </p>
        </div>
        <div
          class="mt-8 px-4 py-3 border border-zinc-800 rounded-lg bg-zinc-900/30 font-mono text-xs text-zinc-500 leading-relaxed"
        >
          <span class="text-zinc-300">Notice:</span> All intellectual property held by
          Modernized AI LLC — codebases, agents, runtimes, and developer tools — is
          shared for educational and research purposes only. It is not offered, marketed,
          sold, or supported as a commercial product, and bears no relation to Overhaul
          products, services, or systems.
        </div>
      </div>
      <div class="bento-card reveal reveal-d3">
        <div class="font-mono text-xs text-zinc-500 mb-4">ENTITY</div>
        <dl class="space-y-3 text-sm">
          <div>
            <dt class="text-zinc-500">Name</dt>
            <dd class="text-zinc-100 mt-0.5">Modernized AI LLC</dd>
          </div>
          <div>
            <dt class="text-zinc-500">Type</dt>
            <dd class="text-zinc-100 mt-0.5">IP holding company</dd>
          </div>
          <div>
            <dt class="text-zinc-500">Founder</dt>
            <dd class="text-zinc-100 mt-0.5">Elliott Bregni</dd>
          </div>
          <div>
            <dt class="text-zinc-500">Location</dt>
            <dd class="text-zinc-100 mt-0.5">Ann Arbor, MI</dd>
          </div>
          <div>
            <dt class="text-zinc-500">Domain</dt>
            <dd class="text-zinc-100 font-mono mt-0.5">modernized-ai.com</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>
